# ── NVIDIA NIM ──────────────────────────────────────────────
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM endpoints (defaults are fine for the public NIM API)
NVIDIA_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ASR_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TTS_BASE_URL=https://integrate.api.nvidia.com/v1

# Models
NVIDIA_LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_ASR_MODEL=nvidia/parakeet-tdt-1.1b
NVIDIA_TTS_VOICE=English-US.Female-1

# ── Aviation APIs ────────────────────────────────────────────
# AviationStack free tier (1000 calls/month): https://aviationstack.com
# Leave blank to use deterministic mock data for flight status.
AVIATIONSTACK_API_KEY=

# ── Server ───────────────────────────────────────────────────
SOCKET_PORT=3001
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ── Client ───────────────────────────────────────────────────
VITE_SOCKET_URL=http://localhost:3001
