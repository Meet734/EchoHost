#NVIDIA NIM
NVIDIA_API_KEY=

#NIM service endpoints
NVIDIA_ASR_ENDPOINT=https://grpc.nvcf.nvidia.com:443
NVIDIA_TTS_ENDPOINT=https://grpc.nvcf.nvidia.com:443
NVIDIA_REASONING_ENDPOINT=https://integrate.api.nvidia.com/v1

#Model identifiers
NVIDIA_ASR_MODEL=nvidia/parakeet-ctc-1.1b # Nemotron-ASR-Streaming
NVIDIA_REASONING_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1 # Nemotron-3 Super
NVIDIA_TTS_MODEL=nvidia/riva-tts # Riva TTS

#Server
SOCKET_PORT=3001
NODE_ENV=development

#Paths
#Absolute or relative (from server/) path to the Silero VAD v5 ONNX model
VAD_MODEL_PATH=./models/silero_vad.onnx

#NeMo Guardrails
GUARDRAILS_CONFIG_PATH=./src/governance/nemo_config
GUARDRAILS_ENABLED=true

#Client
VITE_SOCKET_URL=http://localhost:3001
VITE_ENV=development
